{
  "name": "hcm-independence-socialism-quiz",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "install:all": "npm install && npm install --prefix client",
    "build": "npm run build --prefix client",
    "start": "cross-env NODE_ENV=production node server/index.js",
    "dev": "concurrently \"node server/index.js\" \"npm run dev --prefix client\""
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}